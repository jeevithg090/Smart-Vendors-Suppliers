# Convex URL - this will be set by convex dev command
# VITE_CONVEX_URL=

# Voice Query Feature API Keys

# Sarvam AI API Key (for multilingual speech-to-text)
# Get from: https://sarvam.ai
VITE_SARVAM_API_KEY=sk_30vh1t24_YxCQZZKGkCTWa9zSszUBEyeg

# OpenRouter API Key (for AI responses)
# Get from: https://openrouter.ai
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Translate API Key (optional, for translation fallback)
# Get from: https://cloud.google.com/translate
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Computer Vision API Key (for food item recognition)
# Options: Google Vision API, Clarifai, or Azure Computer Vision
VITE_VISION_API_KEY=your_vision_api_key_here

# Clarifai API Key (alternative computer vision service)
# Get from: https://clarifai.com
VITE_CLARIFAI_API_KEY=your_clarifai_api_key_here

# Azure Computer Vision API Key (alternative)
# Get from: https://azure.microsoft.com/en-us/services/cognitive-services/computer-vision/
VITE_AZURE_VISION_API_KEY=your_azure_vision_api_key_here
VITE_AZURE_VISION_ENDPOINT=your_azure_vision_endpoint_here

# Text-to-Speech API Configuration
# For voice responses in native languages
VITE_TTS_API_KEY=your_tts_api_key_here

# Convex Configuration
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here
