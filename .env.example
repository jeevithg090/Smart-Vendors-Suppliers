VITE_ALGOLIA_SEARCH_KEY=your_algolia_search_key  
VITE_ALGOLIA_INDEX_NAME=vendors

# For setup script only (keep secure)
REACT_APP_ALGOLIA_APP_ID=your_algolia_app_id
REACT_APP_ALGOLIA_ADMIN_KEY=your_algolia_admin_key
REACT_APP_ALGOLIA_INDEX_NAME=vendors

# Convex Configuration
VITE_CONVEX_URL=your_convex_deployment_url
